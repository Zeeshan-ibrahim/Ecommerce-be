PORT=3000
DATABASE_URL="postgresql://username:password@url:port/db-name"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
